# Intentionally no PATH override: the catthehacker image already puts the
# correct bundled Node on PATH. Pinning a patch version here breaks on every
# image bump (node lives at /opt/acttoolcache/node/<version>/x64/bin).

# Testcontainers runs the Ryuk resource-reaper as a sibling container on the
# host Docker daemon, then connects back to its mapped port. Under act the test
# host lives inside the runner container and cannot reach that port across the
# nested-Docker network boundary, so Ryuk init is cancelled and every
# Testcontainers-backed test fails. Disabling Ryuk skips that connect; act runs
# are short-lived so leftover containers are not a concern. This is act-only
# (.act.env) and does not affect real GitHub Actions CI, where Ryuk works.
TESTCONTAINERS_RYUK_DISABLED=true
